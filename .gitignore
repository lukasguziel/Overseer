# Python
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Analysis output (plugin mirrors exports into var/)
var/scene_report.json
var/scene_structure.csv

# Node / Vite
frontend/node_modules/
frontend/dist/

# Local packaging output: release zips built by the release workflow AND the
# Blender addon zip from scripts/release/build_blender_zip.py
# (Overseer-Blender-v*.zip)
dist/

# Vite build output (built from frontend/, distributed by deploy.ps1)
src/web/

# Vendored third-party wheels (Pillow), unpacked by scripts/release/
# vendor_pillow.py (locally and in the release workflow). Generated, never
# committed — no binaries in git.
src/vendor/

# C4D SDK reference archives (large vendor zips) stay local, never in git
var/sdk/

# IDE / temp
.idea/
resp.json
.coverage


# Claude Code project config, skills and instructions stay machine-local —
# the public repo ships without them (CI scripts live in scripts/release/)
.claude/
CLAUDE.md

# Personal working config (the shipped template is config.example.json;
# the plugin falls back to DEFAULT_CONFIG when no config.json exists)
src/config.json

# runtime logs written by the plugin
change_history.json
analysis_history.json

# Playwright MCP session artifacts
.playwright-mcp/

# Playwright e2e artifacts (frontend/playwright.config.ts)
frontend/test-results/
frontend/playwright-report/
